{# Layout base HEREDABLE de página. Las vistas de módulo hacen
   `{% extends "index.html.j2" %}` y rellenan `{% block content %}`.
   `app_name`, `t()` y `asset()` son globales del TemplateEngine. #}
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}{{ app_name }}{% endblock %}</title>
  <link rel="stylesheet" href="{{ asset('welcome.css') }}">
  {% block head %}{% endblock %}
</head>
<body>
  {% block content %}{% endblock %}
</body>
</html>