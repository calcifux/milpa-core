# Configuración de __PROJECT__ (copia este archivo a `.env` y ajústalo).
# El `.env` NUNCA se sube a git (lleva secretos).

APP_NAME=__PROJECT__
APP_ENV=local
APP_PORT=8000

# --- Base de datos (OBLIGATORIA) ---
# Por default sqlite local. Para otros motores: DATABASE_URL=postgresql+psycopg://...
DATABASE_URL=sqlite:///./__PROJECT__.db

# --- Dónde vive TU código (esto es lo que vuelve a milpa "consciente" de tu proyecto) ---
MODULES_PACKAGE=app.Modules
MODELS_PACKAGE=app.Models
APP_COMMANDS_PACKAGE=app.Console.Commands
MIGRATIONS_DIR=migrations
USER_VIEWS_DIR=app/Resources/Views
USER_STATIC_DIR=app/Resources/Static
AUTH_USER_MODEL=app.Models.User.User

# --- Secretos de auth (genera los tuyos) ---
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
SESSION_SECRET=

# --- Locale / zona horaria ---
APP_FALLBACK_LOCALE=es
TIMEZONE=America/Mexico_City
