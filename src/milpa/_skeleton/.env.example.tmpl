# Configuración de __PROJECT__ (copia este archivo a `.env` y ajústalo).
# El `.env` NUNCA se sube a git (lleva secretos).

APP_NAME=__PROJECT__
APP_ENV=local
APP_PORT=8000

# --- Base de datos (OBLIGATORIA) ---
# Por default sqlite local. Para otros motores: DATABASE_URL=postgresql+psycopg://...
DATABASE_URL=sqlite:///./__PROJECT__.db

# --- Dónde vive TU código (esto es lo que vuelve a milpa "consciente" de tu proyecto) ---
MODULES_PACKAGE=app.Modules
MODELS_PACKAGE=app.Models
APP_COMMANDS_PACKAGE=app.Console.Commands
APP_DIR=app
MIGRATIONS_DIR=migrations
USER_VIEWS_DIR=app/Resources/Views
USER_STATIC_DIR=app/Resources/Static
AUTH_USER_MODEL=app.Models.User.User

# --- Secretos de auth (genera los tuyos) ---
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
SESSION_SECRET=

# --- Correo (el demo manda correos al crear notas / registrar usuarios) ---
# MAIL_DRIVER=log  -> NO manda correos de verdad: los IMPRIME en la MISMA terminal donde corre
#   `jornal serve` (así VES "Tu nota fue creada", etc. sin montar nada). Es el default para empezar.
#   "smtp" = manda de verdad · "null" = los descarta.
MAIL_DRIVER=log
# Para verlos como un INBOX WEB real: pon MAIL_DRIVER=smtp, levanta Mailpit (`docker compose up -d`)
# y abre http://localhost:8025  (host/puerto de abajo ya apuntan a Mailpit).
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=no-reply@__PROJECT__.test
MAIL_FROM_NAME="__PROJECT__"

# --- Colas / broker (para @job y @cron_task; OPCIONAL) ---
# Default redis local. Si NO levantas redis, los @job y los correos por evento corren SÍNCRONOS.
# Para async real: `docker compose up -d` + un worker (`jornal queue work`).
BROKER_URL=

# --- Vite / frontend (OPT-IN, estilo laravel-vite) ---
# milpa AUTO-DETECTA apps frontend en surcos/: toda carpeta con `hot` (dev server
# corriendo) o `dist/.vite/manifest.json` (build hecho) se sirve sola; sin apps no se
# monta nada. Estos defaults ya funcionan con los surcos del demo (`milpa new --demo`)
# — descomenta SOLO para cambiarlos.
# VITE_APPS_DIR=surcos          # fuentes de los surcos (un microfrontend por vertical)
# VITE_PUBLIC_DIR=public        # los builds caen en public/<surco> (lo hace vite-plugin-milpa)
# VITE_ASSETS_URL=/vite         # raíz pública; DEBE coincidir con el `base` del vite.config
# Modo UNA-SOLA-APP (frontend en la raíz del proyecto, estilo Laravel clásico):
# apunta directo al dist y se ignora la auto-detección.
# VITE_DIST_DIR=                # ej. public/vite
# VITE_HOT_FILE=                # vacío => "<dist>/../hot"
# Prefijo público que asset() y vite() anteponen a las URLs (reverse proxy bajo
# sub-ruta o CDN). DEBE ser el MISMO ASSET_URL con el que se buildea el frontend
# (vite-plugin-milpa lee esta misma var en build).
# ASSET_URL=                    # ej. /mi-app  o  https://cdn.ejemplo.com

# --- Locale / zona horaria ---
APP_FALLBACK_LOCALE=es
TIMEZONE=America/Mexico_City
