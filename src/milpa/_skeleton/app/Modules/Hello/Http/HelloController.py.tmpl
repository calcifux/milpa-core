from __future__ import annotations

from fastapi.responses import HTMLResponse

from fastapi import APIRouter

from milpa.Core.View import view

router = APIRouter(tags=["hello"])


@router.get("/hello")
async def hello() -> dict[str, str]:
    """Ruta JSON de cortesía: confirma que milpa descubrió tu módulo."""
    return {"mensaje": "¡milpa está sembrada! 🌽", "modulo": "Hello"}


@router.get("/", response_class=HTMLResponse)
async def welcome() -> HTMLResponse:
    """Página de bienvenida: renderiza app/Resources/Views/welcome.html.j2."""
